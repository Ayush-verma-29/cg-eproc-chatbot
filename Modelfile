# Model configuration file for Ollama

# 1. Point to your fine-tuned GGUF file 
# (Update this path if you place the downloaded GGUF file elsewhere)
FROM ./cg_procurement_model.gguf

# 2. Set default parameters for factual retrieval
PARAMETER temperature 0.2
PARAMETER top_k 40
PARAMETER top_p 0.9
PARAMETER stop "<|im_end|>"
PARAMETER stop "<|eot_id|>"

# 3. Define the system prompt matched during training
SYSTEM """You are an expert procurement assistant for the Chhattisgarh e-Procurement Portal. Provide accurate, precise, and verified answers with bracketed citations based strictly on the provided context. Always treat the Chhattisgarh Store Purchase Rules as the primary authority."""
